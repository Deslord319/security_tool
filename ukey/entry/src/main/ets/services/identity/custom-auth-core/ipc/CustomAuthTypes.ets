// IPC command codes aligned with ICustomAuthenticatorV1.
export enum IpcCode {
  COMMAND_INIT_AUTHENTICATOR = 50000,
  COMMAND_BEGIN_ENROLL = 50001,
  COMMAND_END_ENROLL = 50002,
  COMMAND_BEGIN_AUTHENTICATE = 50003,
  COMMAND_SUBMIT_PASSCODE = 50004,
  COMMAND_REMOVE = 50005,
  COMMAND_CANCEL = 50006,
  COMMAND_ON_ENROLL_RESULT = 50010,
  COMMAND_ON_AUTH_RESULT = 50011,
  COMMAND_ON_PROMPT = 50012,
}

export const CUSTOM_AUTH_INTERFACE_DESCRIPTOR =
  'OHOS.UserIam.CustomAuth.ICustomAuthenticatorV1.ICustomAuthenticator'
export const CUSTOM_AUTH_CALLBACK_DESCRIPTOR =
  'OHOS.UserIam.CustomAuth.ICustomAuthenticatorV1.ICustomAuthCallback'

// Algorithm ids exchanged with the framework.
export enum AsymmetricKeyExchangeAlgorithm {
  ECDH_P256 = 1,
}

export enum KeyDerivationAlgorithm {
  HKDF_SHA256 = 1,
}

export enum AsymmetricEncryptionAlgorithm {
  RSA_4096_OAEP_SHA256 = 1,
}

export enum SymmetricEncryptionAlgorithm {
  AES_256_GCM = 1,
}

// Result codes returned by the authenticator.
export enum ResultCode {
  SUCCESS = 0,
  FAIL = 1,
  GENERAL_ERROR = 2,
  CANCELED = 3,
  TIMEOUT = 4,
  BUSY = 7,
  LOCKED = 9,
  NOT_ENROLLED = 10,
}

export interface EncryptedData {
  nonce: number[]
  tag: number[]
  ciphertext: number[]
}

// Reserved algorithm parameters carried by beginEnroll / beginAuthenticate.
export interface AlgorithmParam {
  asymmetricKeyExchangeAlgorithm: number
  asymmetricEncryptionAlgorithm: number
  symmetricEncryptionAlgorithm: number
  keyDerivationAlgorithm: number
}

// initAuthenticator response: capabilities plus reconciled template ids.
export interface InitOutput {
  asymmetricKeyExchangeAlgorithms: number[]
  asymmetricEncryptionAlgorithms: number[]
  symmetricEncryptionAlgorithms: number[]
  keyDerivationAlgorithms: number[]
  authenticatorTemplateIds: string[]
}

export interface InitAuthenticatorResult {
  resultCode: number
  initOutput: InitOutput
}

export interface BeginEnrollInput {
  requestId: number
  algorithmParam: AlgorithmParam
}

export interface EnrollCallbackResult {
  resultCode: number
  challenge: number[]
  publicKey: number[]
}

// EndEnrollInput carries the template id generated by the framework.
export interface EndEnrollInput {
  requestId: number
  templateId: string
  userId: number
  userEnrolledTemplateIds: string[]
  salt: number[]
  publicKey: number[] // cdaPub
  challenge: number[] // cdaChallenge
  encryptedData: EncryptedData
}

export interface EndEnrollOutput {
  resultCode: number
  encryptedData: EncryptedData
}

export interface BeginAuthenticateInput {
  requestId: number
  algorithmParam: AlgorithmParam
  userId: number
  salt: number[]
  challenge: number[] // cdaChallenge
}

// onPrompt carries templateId outside AEAD so the framework can choose the right sharedKey.
export interface PromptInfo {
  templateId: string
  encryptedData: EncryptedData
}

// onAuthResult returns templateId "0" on failure.
export interface AuthCallbackResult {
  resultCode: number
  templateId: string
  encryptedData: EncryptedData
}

export interface AuthTipInfo {
  tipCode: number // 50000-59999
  tipInfo: string
}
