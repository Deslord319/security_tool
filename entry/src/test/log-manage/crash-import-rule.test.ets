import { afterEach, beforeEach, describe, expect, it } from '@ohos/hypium'
import { LogEventResult, LogEventType } from '../../main/ets/models/LogModels'
import { CrashLogImportRule } from '../../main/ets/services/log-manage/import/CrashLogImportRule'
import { ImportedLogFile } from '../../main/ets/services/log-manage/import/LogImportRule'

let testContents: Map<string, string> = new Map<string, string>()

function createFile(relativePath: string, content?: string): ImportedLogFile {
  let path = `crash_import_rule_${relativePath.replace(/\//g, '_')}_${Date.now()}_${Math.floor(Math.random() * 100000)}`
  if (content !== undefined) {
    testContents.set(path, content)
  }
  return {
    path,
    fileName: relativePath.substring(relativePath.lastIndexOf('/') + 1),
    relativePath,
    normalizedPath: relativePath
  }
}

function sampleAppFreeze(reason: string = 'THREAD_BLOCK_6S'): string {
  return [
    'Generated by HiviewDFX@OpenHarmony',
    'Module name:com.huawei.securitytool',
    'Pid:23766',
    'Uid:20020153',
    `Reason:${reason}`,
    'TIMESTAMP:2026/05/11-14:17:12:858',
    'PROCESS_NAME:com.huawei.securitytool',
    'MSG = App main thread is not response!',
    '#00 pc 00000000003cfa90 /system/lib64/platformsdk/libark_jsruntime.so'
  ].join('\n')
}

export default function crashImportRuleTest() {
  describe('CrashLogImportRule', () => {
    beforeEach(() => {
      testContents = new Map<string, string>()
      CrashLogImportRule.setLineReaderForTest(async (file: ImportedLogFile, onLine: (line: string, lineNumber: number) => Promise<void>): Promise<void> => {
        let content = testContents.get(file.path) ?? ''
        let lines = content.split(/\r?\n/)
        for (let index = 0; index < lines.length; index++) {
          await onLine(lines[index], index + 1)
        }
      })
    })

    afterEach(() => {
      CrashLogImportRule.resetTestPorts()
    })

    it('should only handle known faultlogger crash files', 0, () => {
      let rule = new CrashLogImportRule()

      expect(rule.canHandle(createFile('remoteLog/faultlogger/appfreeze-com.huawei.securitytool-20020153-20260511141712858.log'))).assertTrue()
      expect(rule.canHandle(createFile('remoteLog/faultlogger/jscrash-com.huawei.securitytool-20020153-20260511112251885.log'))).assertTrue()
      expect(rule.canHandle(createFile('remoteLog/faultlogger/cppcrash-com.example.demo-20020152-20260507094000200.log'))).assertTrue()
      expect(rule.canHandle(createFile('remoteLog/faultlogger/random.log'))).assertFalse()
      expect(rule.canHandle(createFile('remoteLog/hilog/appfreeze-com.huawei.securitytool-20020153-20260511141712858.log'))).assertFalse()
    })

    it('should parse appfreeze file into one failed crash entry', 0, async () => {
      let result = await new CrashLogImportRule().parse(createFile(
        'remoteLog/faultlogger/appfreeze-com.huawei.securitytool-20020153-20260511141712858.log',
        sampleAppFreeze()
      ))

      expect(result.entries.length).assertEqual(1)
      expect(result.droppedCount).assertEqual(0)
      expect(result.failedCount).assertEqual(0)
      expect(result.entries[0].eventType).assertEqual(LogEventType.CRASH)
      expect(result.entries[0].result).assertEqual(LogEventResult.FAILED)
      expect(result.entries[0].rawEventName).assertEqual('appfreeze')
      expect(result.entries[0].rawOutcome).assertEqual('freeze')
      expect(result.entries[0].processName).assertEqual('com.huawei.securitytool')
      expect(result.entries[0].pid).assertEqual(23766)
      expect(result.entries[0].uid).assertEqual(20020153)
      expect(result.entries[0].detail.indexOf('THREAD_BLOCK_6S') >= 0).assertTrue()
    })

    it('should parse jscrash and cppcrash summaries', 0, async () => {
      let jsContent = [
        'Timestamp:2026-05-11 11:22:51.885',
        'Module name:com.huawei.securitytool',
        'Pid:33018',
        'Uid:20020153',
        'Reason:OutOfMemoryError',
        'Error name:OutOfMemoryError',
        'Error message:SharedHeap OOM',
        '    at decodeToString (/system/lib64/module/libutil.z.so:747:1)'
      ].join('\n')
      let cppContent = [
        'Timestamp:2026-05-07 09:40:00.200',
        'Module name:com.example.netfirewalldemo',
        'Pid:30345',
        'Uid:20020152',
        'Process name:com.example.netfirewalldemo',
        'Reason:Signal:SIGSEGV(SEGV_MAPERR)@000000000000000000',
        '#00 pc 0000000000001ad8 /data/storage/el1/bundle/libs/arm64/libcppcrash.so'
      ].join('\n')

      let jsResult = await new CrashLogImportRule().parse(createFile(
        'remoteLog/faultlogger/jscrash-com.huawei.securitytool-20020153-20260511112251885.log',
        jsContent
      ))
      let cppResult = await new CrashLogImportRule().parse(createFile(
        'remoteLog/faultlogger/cppcrash-com.example.netfirewalldemo-20020152-20260507094000200.log',
        cppContent
      ))

      expect(jsResult.entries.length).assertEqual(1)
      expect(jsResult.entries[0].rawEventName).assertEqual('jscrash')
      expect(jsResult.entries[0].rawOutcome).assertEqual('crash')
      expect(jsResult.entries[0].detail.indexOf('OutOfMemoryError') >= 0).assertTrue()
      expect(cppResult.entries.length).assertEqual(1)
      expect(cppResult.entries[0].rawEventName).assertEqual('cppcrash')
      expect(cppResult.entries[0].processName).assertEqual('com.example.netfirewalldemo')
      expect(cppResult.entries[0].detail.indexOf('SIGSEGV') >= 0).assertTrue()
    })

    it('should dedupe by content and timestamp without source path', 0, async () => {
      let first = await new CrashLogImportRule().parse(createFile(
        'remoteLog/faultlogger/appfreeze-com.huawei.securitytool-20020153-20260511141712858.log',
        sampleAppFreeze()
      ))
      let sameContentDifferentSource = await new CrashLogImportRule().parse(createFile(
        'other/faultlogger/appfreeze-com.huawei.securitytool-20020153-20260511141712858.log',
        sampleAppFreeze()
      ))
      let differentTimestamp = await new CrashLogImportRule().parse(createFile(
        'remoteLog/faultlogger/appfreeze-com.huawei.securitytool-20020153-20260511141712859.log',
        sampleAppFreeze().replace('TIMESTAMP:2026/05/11-14:17:12:858', 'TIMESTAMP:2026/05/11-14:17:12:859')
      ))

      expect(first.entries[0].id).assertEqual(sameContentDifferentSource.entries[0].id)
      expect(first.entries[0].id === differentTimestamp.entries[0].id).assertFalse()
    })

    it('should drop invalid faultlogger file', 0, async () => {
      let result = await new CrashLogImportRule().parse(createFile(
        'remoteLog/faultlogger/appfreeze-com.huawei.securitytool-20020153-20260511141712858.log',
        'Generated by HiviewDFX@OpenHarmony'
      ))

      expect(result.entries.length).assertEqual(0)
      expect(result.droppedCount).assertEqual(1)
      expect(result.failedCount).assertEqual(0)
    })
  })
}
