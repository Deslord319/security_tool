{
  "case_id": "FW-STATUS-001",
  "case_name": "Firewall Status Toggle",
  "module": "firewall",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_firewall_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "firewall"
      }
    },
    {
      "name": "toggle_firewall",
      "ref": "firewall.toggle_status",
      "params": {
        "target_state": "invert",
        "require_auth_prompt": true,
        "require_auth_handled": true
      }
    }
  ],
  "assertions": [
    {
      "name": "firewall_page_still_visible_after_toggle",
      "type": "assert_text_presence",
      "value": "公共网络模式",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Current primary evidence confirms the authenticated toggle flow returns to a stable firewall page state.",
    "Primary assertion will move to a service-backed firewall status read once getter execution is wired in."
  ]
}
