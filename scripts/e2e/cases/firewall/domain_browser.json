{
  "case_id": "FW-DOMAIN-001",
  "case_name": "Firewall Domain Rule Browser Verification",
  "module": "firewall",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_firewall_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "firewall"
      }
    },
    {
      "name": "add_domain_rule",
      "ref": "entity.create",
      "params": {
        "domain": "firewall",
        "entity": "rule",
        "variant": "domain",
        "data": {
          "domain": "www.baidu.com",
          "direction": "out",
          "policy": "deny"
        }
      }
    },
    {
      "name": "open_browser_url",
      "ref": "browser.open_url",
      "params": {
        "url": "https://www.baidu.com"
      }
    }
  ],
  "assertions": [
    {
      "name": "domain_rule_visible_before_browser_verification",
      "type": "assert_text_presence",
      "value": "www.baidu.com",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2500,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Current primary evidence proves the deny rule is created before browser-side verification begins.",
    "This case verifies domain rule creation and browser access behavior for www.baidu.com."
  ]
}
