{
  "case_id": "FW-RULE-001",
  "case_name": "Firewall Domain Rule Create",
  "module": "firewall",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_firewall_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "firewall"
      }
    },
    {
      "name": "create_domain_rule",
      "ref": "entity.create",
      "params": {
        "domain": "firewall",
        "entity": "rule",
        "variant": "domain",
        "data": {
          "domain": "www.baidu.com",
          "direction": "out",
          "policy": "deny"
        }
      }
    },
    {
      "name": "capture_domain_rule_created",
      "ref": "ui.capture_screenshot",
      "params": {
        "name": "firewall_domain_rule_created"
      }
    }
  ],
  "assertions": [],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Primary rule list assertion will later be backed by a firewall getter."
  ]
}
