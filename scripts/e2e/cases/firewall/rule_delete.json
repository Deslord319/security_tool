{
  "case_id": "FW-RULE-002",
  "case_name": "Firewall Domain Rule Delete",
  "module": "firewall",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_firewall_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "firewall"
      }
    },
    {
      "name": "delete_domain_rule",
      "ref": "entity.delete",
      "params": {
        "domain": "firewall",
        "entity": "rule",
        "variant": "domain",
        "data": {
          "domain": "www.baidu.com"
        }
      }
    }
  ],
  "assertions": [
    {
      "name": "deleted_domain_rule_not_visible",
      "type": "assert_text_presence",
      "value": "www.baidu.com",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": false,
        "timeout_ms": 2500,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Delete case assumes the completeness suite has already created the target domain rule.",
    "Current primary evidence confirms the deleted domain is no longer visible in the rules list."
  ]
}
