{
  "case_id": "FW-RULES-003",
  "case_name": "Firewall Rules Page Visible",
  "module": "firewall",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_firewall_rules_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "firewall-rules"
      }
    }
  ],
  "assertions": [
    {
      "name": "firewall_rules_add_button_visible",
      "type": "assert_text_presence",
      "value": "新增规则",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    },
    {
      "name": "firewall_rules_outbound_section_visible",
      "type": "assert_text_presence",
      "value": "出站规则",
      "level": "secondary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This case isolates firewall rules page reachability from create/delete behavior."
  ]
}
