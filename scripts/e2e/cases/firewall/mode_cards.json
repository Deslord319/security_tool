{
  "case_id": "FW-MODE-001",
  "case_name": "Firewall Mode Cards Visible",
  "module": "firewall",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_firewall_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "firewall"
      }
    }
  ],
  "assertions": [
    {
      "name": "firewall_public_mode_visible",
      "type": "assert_text_presence",
      "value": "公共网络模式",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    },
    {
      "name": "firewall_private_mode_visible",
      "type": "assert_text_presence",
      "value": "私有网络模式",
      "level": "secondary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This case supplements firewall coverage with preset mode card visibility."
  ]
}
