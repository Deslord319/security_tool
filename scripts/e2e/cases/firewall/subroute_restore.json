{
  "case_id": "FW-ROUTE-001",
  "case_name": "Firewall Rules Subroute Restore After Module Switch",
  "module": "firewall",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_firewall_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "firewall"
      }
    },
    {
      "name": "open_firewall_rules",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "firewall-rules",
        "rule_type": "domain"
      }
    },
    {
      "name": "switch_to_identity",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "identity"
      }
    },
    {
      "name": "return_to_firewall",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "firewall"
      }
    }
  ],
  "assertions": [
    {
      "name": "rules_subroute_restored",
      "type": "assert_text_presence",
      "value": "新增规则",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2500,
        "interval_ms": 250
      }
    },
    {
      "name": "firewall_main_card_not_restored_over_rules",
      "type": "assert_text_presence",
      "value": "公共网络模式",
      "level": "secondary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": false,
        "timeout_ms": 1500,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This covers the reported firewall state issue: returning from another module must restore the previously selected custom-rules subroute."
  ]
}
