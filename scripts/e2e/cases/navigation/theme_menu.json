{
  "case_id": "NAV-MENU-001",
  "case_name": "Theme Menu Visible",
  "module": "navigation",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_theme_menu",
      "ref": "theme_menu.open",
      "params": {}
    },
    {
      "name": "capture_theme_menu",
      "ref": "ui.capture_screenshot",
      "params": {
        "name": "top_menu_open"
      }
    }
  ],
  "assertions": [
    {
      "name": "help_feedback_menu_item_visible",
      "type": "assert_text_presence",
      "value": "帮助与反馈",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Theme menu visibility is confirmed through a stable visible menu entry."
  ]
}
