{
  "case_id": "NAV-TOOLS-001",
  "case_name": "Tool Settings Page Reachable",
  "module": "navigation",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_tool_settings_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "tool-settings"
      }
    }
  ],
  "assertions": [
    {
      "name": "tool_settings_password_entry_visible",
      "type": "assert_text_presence",
      "value": "修改密码",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This case verifies the sidebar route into tool settings remains reachable.",
    "Primary evidence uses the stable password-entry row title."
  ]
}
