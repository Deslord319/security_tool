{
  "case_id": "NAV-IDENTITY-001",
  "case_name": "Identity Page Reachable",
  "module": "navigation",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_identity_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "identity"
      }
    }
  ],
  "assertions": [
    {
      "name": "identity_password_section_visible",
      "type": "assert_text_presence",
      "value": "口令复杂度策略",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This case verifies the left-rail route into the identity page remains reachable.",
    "Primary evidence uses the password policy section title."
  ]
}
