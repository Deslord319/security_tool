{
  "case_id": "APP-INSTALL-001",
  "case_name": "安装与启动链路检查",
  "module": "bootstrap",
  "steps": [
    {
      "name": "确认应用已安装",
      "type": "assert_hdc_shell_contains",
      "command": "bm dump -n {{bundle_name}}",
      "contains": "{{bundle_name}}",
      "timeout_sec": 20
    },
    {
      "name": "启动 EntryAbility",
      "type": "hdc_shell",
      "command": "aa start -a EntryAbility -b {{bundle_name}}",
      "timeout_sec": 20
    },
    {
      "name": "再次确认 bundle 可查询",
      "type": "assert_hdc_shell_contains",
      "command": "bm dump -n {{bundle_name}}",
      "contains": "EntryAbility",
      "timeout_sec": 20
    }
  ],
  "notes": [
    "这条用例不负责重新安装 HAP，只验证设备上当前安装包的可启动性。"
  ]
}
