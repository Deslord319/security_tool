{
  "case_id": "FW-STATUS-001",
  "case_name": "防火墙开关状态切换与回读",
  "module": "firewall",
  "steps": [
    {
      "name": "导航到防火墙管理",
      "type": "mcp_action",
      "action": "navigate_page",
      "params": {
        "page": "防火墙管理"
      },
      "expected": "防火墙管理页面显示"
    },
    {
      "name": "切换防火墙开关",
      "type": "mcp_action",
      "action": "toggle_firewall",
      "params": {
        "target_state": "invert"
      },
      "expected": "页面开关状态变化"
    },
    {
      "name": "记录系统状态说明",
      "type": "note",
      "message": "主断言应以 FirewallService.getFirewallStatus() 返回值为准，MCP 页面开关作为辅助证据。"
    }
  ],
  "notes": [
    "建议执行后再切回原状态，避免影响后续规则测试。"
  ]
}
