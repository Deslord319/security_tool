{
  "case_id": "SET-STARTUP-001",
  "case_name": "启动时身份校验开关保存",
  "module": "tool-settings",
  "steps": [
    {
      "name": "导航到工具设置",
      "type": "mcp_action",
      "action": "navigate_page",
      "params": {
        "page": "工具设置"
      },
      "expected": "工具设置页面显示"
    },
    {
      "name": "切换启动时身份校验开关",
      "type": "mcp_action",
      "action": "toggle_startup_auth",
      "params": {
        "target_state": "invert"
      },
      "expected": "开关状态变化且可保存"
    },
    {
      "name": "点击保存设置",
      "type": "mcp_action",
      "action": "save_tool_settings",
      "params": {},
      "expected": "页面出现保存成功反馈"
    }
  ],
  "notes": [
    "这项目前主要依赖 UI 回显和重进页面状态。"
  ]
}
