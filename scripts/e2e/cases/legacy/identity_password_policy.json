{
  "case_id": "ID-PWD-001",
  "case_name": "口令复杂度策略保存与回读",
  "module": "identity",
  "steps": [
    {
      "name": "导航到身份鉴别",
      "type": "mcp_action",
      "action": "navigate_page",
      "params": {
        "page": "身份鉴别"
      },
      "expected": "身份鉴别页面显示"
    },
    {
      "name": "修改口令复杂度策略",
      "type": "mcp_action",
      "action": "update_password_policy",
      "params": {
        "min_length": 8,
        "require_uppercase": true,
        "require_lowercase": true,
        "require_digit": true,
        "require_special_char": true
      },
      "expected": "保存提示出现"
    }
  ],
  "notes": [
    "主断言建议接 IdentityService.getPasswordPolicyWithResult()。"
  ]
}
