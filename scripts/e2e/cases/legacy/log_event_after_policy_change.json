{
  "case_id": "LOG-EVENT-001",
  "case_name": "策略变更后产生审计事件",
  "module": "log-manage",
  "steps": [
    {
      "name": "执行一次策略变更",
      "type": "mcp_action",
      "action": "change_any_policy",
      "params": {
        "preferred_module": "firewall"
      },
      "expected": "策略变更成功"
    },
    {
      "name": "抓取最近日志",
      "type": "hdc_shell",
      "command": "hilog -x | grep com.huawei.securitytool",
      "timeout_sec": 10
    }
  ],
  "notes": [
    "后续需要结合日志页列表和设备日志共同判定。"
  ]
}
