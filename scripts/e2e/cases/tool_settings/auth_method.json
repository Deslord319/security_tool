{
  "case_id": "SET-AUTH-001",
  "case_name": "Tool Settings Auth Method",
  "module": "tool-settings",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_tool_settings",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "tool-settings"
      }
    },
    {
      "name": "update_auth_method",
      "ref": "entity.update",
      "params": {
        "domain": "tool_settings",
        "entity": "auth_method",
        "data": {
          "method": "PIN"
        }
      }
    }
  ],
  "assertions": [
    {
      "name": "tool_settings_page_visible_after_auth_method_update",
      "type": "assert_text_presence",
      "value": "身份认证方式",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Current primary evidence confirms the auth method update runs in the expected settings section.",
    "Selection persistence assertion will be added after page re-entry verification is implemented."
  ]
}
