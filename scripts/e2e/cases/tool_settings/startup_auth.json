{
  "case_id": "SET-STARTUP-001",
  "case_name": "Startup Auth Toggle",
  "module": "tool-settings",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_tool_settings",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "tool-settings"
      }
    },
    {
      "name": "toggle_startup_auth_setting",
      "ref": "entity.toggle",
      "params": {
        "domain": "tool_settings",
        "entity": "startup_auth",
        "data": {
          "target_state": "invert"
        }
      }
    }
  ],
  "assertions": [],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Primary evidence remains UI-level until a stable preference getter is exposed."
  ]
}
