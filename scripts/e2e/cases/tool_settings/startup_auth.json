{
  "case_id": "SET-STARTUP-001",
  "case_name": "Startup Auth Toggle",
  "module": "tool-settings",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "reset_previous_page",
      "ref": "ui.press_key",
      "params": {
        "key": "BACK"
      }
    },
    {
      "name": "relaunch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_tool_settings",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "tool-settings"
      }
    },
    {
      "name": "toggle_startup_auth_setting",
      "ref": "entity.toggle",
      "params": {
        "domain": "tool_settings",
        "entity": "startup_auth",
        "data": {
          "target_state": "invert"
        }
      }
    }
  ],
  "assertions": [
    {
      "name": "tool_settings_page_marker_visible",
      "type": "assert_text_presence",
      "value": "工具设置",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Current primary evidence confirms the toggle flow remains on the correct settings section.",
    "Primary evidence remains UI-level until a stable preference getter is exposed."
  ]
}
