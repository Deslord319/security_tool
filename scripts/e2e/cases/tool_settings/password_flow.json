{
  "case_id": "SET-PASSWORD-001",
  "case_name": "Tool Settings Password Flow",
  "module": "tool-settings",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_tool_settings",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "tool-settings"
      }
    },
    {
      "name": "set_tool_password",
      "ref": "tool_settings.set_password",
      "params": {
        "current_password": "",
        "new_password": "1234",
        "confirm_password": "1234"
      }
    }
  ],
  "assertions": [
    {
      "name": "tool_password_form_context_visible",
      "type": "assert_text_presence",
      "value": "修改密码",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Current primary evidence confirms the password flow executes in the expected form context.",
    "Negative password scenarios will be added as separate cases."
  ]
}
