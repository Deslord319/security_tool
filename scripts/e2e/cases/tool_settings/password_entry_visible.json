{
  "case_id": "SET-PASSWORD-002",
  "case_name": "Tool Settings System Password Entry Roundtrip",
  "module": "tool-settings",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_tool_settings",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "tool-settings"
      }
    },
    {
      "name": "open_system_password_settings_entry",
      "ref": "tool_settings.set_password",
      "params": {}
    },
    {
      "name": "return_tool_settings",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "tool-settings"
      }
    }
  ],
  "assertions": [
    {
      "name": "tool_settings_page_recovered",
      "type": "assert_text_presence",
      "value": "工具设置",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    },
    {
      "name": "system_password_entry_still_available",
      "type": "assert_text_presence",
      "value": "修改密码",
      "level": "secondary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This covers the handoff to the system password settings surface and verifies the app returns to the tool-settings workflow."
  ]
}
