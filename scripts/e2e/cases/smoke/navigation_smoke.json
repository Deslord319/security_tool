{
  "case_id": "NAV-SMOKE-001",
  "case_name": "Navigation Smoke",
  "module": "navigation",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_dashboard",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "dashboard"
      }
    },
    {
      "name": "open_firewall",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "firewall"
      }
    },
    {
      "name": "open_log_manage",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "log-manage"
      }
    },
    {
      "name": "open_peripheral_manage",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "peripheral-manage"
      }
    },
    {
      "name": "open_identity",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "identity"
      }
    },
    {
      "name": "open_tool_settings",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "tool-settings"
      }
    }
  ],
  "assertions": [
    {
      "name": "tool_settings_page_visible",
      "type": "assert_text_presence",
      "value": "启动时身份校验",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Primary checkpoint uses the final tool settings page marker to confirm the navigation chain reaches the expected terminal page."
  ]
}
