{
  "case_id": "DASH-OVERVIEW-003",
  "case_name": "Dashboard Quick Entries Visible",
  "module": "dashboard",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_dashboard",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "dashboard"
      }
    }
  ],
  "assertions": [
    {
      "name": "dashboard_identity_entry_visible",
      "type": "assert_text_presence",
      "value": "身份鉴别",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    },
    {
      "name": "dashboard_help_entry_visible",
      "type": "assert_text_presence",
      "value": "帮助与反馈",
      "level": "secondary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This case checks that dashboard quick-entry tiles expose additional modules beyond the existing overview case."
  ]
}
