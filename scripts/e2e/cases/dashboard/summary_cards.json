{
  "case_id": "DASH-OVERVIEW-002",
  "case_name": "Dashboard Summary Cards Visible",
  "module": "dashboard",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_dashboard",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "dashboard"
      }
    }
  ],
  "assertions": [
    {
      "name": "dashboard_log_card_visible",
      "type": "assert_text_presence",
      "value": "日志记录",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    },
    {
      "name": "dashboard_firewall_card_visible",
      "type": "assert_text_presence",
      "value": "防火墙模式",
      "level": "secondary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This case supplements dashboard coverage with additional summary-card visibility checks."
  ]
}
