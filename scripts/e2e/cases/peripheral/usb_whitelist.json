{
  "case_id": "PER-WL-USB-001",
  "case_name": "Peripheral USB Whitelist Create",
  "module": "peripheral",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_peripheral_manage",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "peripheral-manage"
      }
    },
    {
      "name": "create_usb_whitelist_entry",
      "ref": "entity.create",
      "params": {
        "domain": "peripheral",
        "entity": "whitelist",
        "variant": "usb",
        "data": {
          "device_id": "USB-ALLOW-001"
        }
      }
    }
  ],
  "assertions": [
    {
      "name": "peripheral_whitelist_context_visible",
      "type": "assert_text_presence",
      "value": "黑白名单",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Current primary evidence confirms the whitelist flow executes in the expected peripheral policy context.",
    "Device-level whitelist getter assertions will be added after policy readback is wired."
  ]
}
