{
  "case_id": "PER-USB-WHITELIST-001",
  "case_name": "Peripheral USB Whitelist Add",
  "module": "peripheral",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_peripheral_manage",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "peripheral-manage"
      }
    },
    {
      "name": "create_usb_whitelist_entry",
      "ref": "entity.create",
      "params": {
        "domain": "peripheral",
        "entity": "whitelist",
        "variant": "usb",
        "data": {
          "vendor_id": "0781",
          "product_id": "5583"
        }
      }
    }
  ],
  "assertions": [],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Whitelist list assertion will be attached after service-backed reads are integrated."
  ]
}
