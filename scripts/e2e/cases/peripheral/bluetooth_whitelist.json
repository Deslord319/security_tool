{
  "case_id": "PER-WL-BT-001",
  "case_name": "Peripheral Record Tab Export Entry",
  "module": "peripheral",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_peripheral_manage",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "peripheral-manage"
      }
    },
    {
      "name": "open_peripheral_record_tab",
      "ref": "ui.click_text",
      "params": {
        "text": "设备连接记录",
        "bundle_name": "{{bundle_name}}"
      }
    }
  ],
  "assertions": [
    {
      "name": "peripheral_record_export_visible",
      "type": "assert_text_presence",
      "value": "导出记录",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Current app version exposes device history in a dedicated 设备连接记录 tab.",
    "This case verifies the record tab can be opened and its export entry is visible."
  ]
}
