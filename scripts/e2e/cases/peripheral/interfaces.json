{
  "case_id": "PER-IF-001",
  "case_name": "Peripheral Interface Toggle",
  "module": "peripheral",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_peripheral_manage",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "peripheral-manage"
      }
    },
    {
      "name": "toggle_usb_interface",
      "ref": "entity.toggle",
      "params": {
        "domain": "peripheral",
        "entity": "interface",
        "variant": "usb",
        "data": {
          "target_state": "invert"
        }
      }
    },
    {
      "name": "toggle_bluetooth_interface",
      "ref": "entity.toggle",
      "params": {
        "domain": "peripheral",
        "entity": "interface",
        "variant": "bluetooth",
        "data": {
          "target_state": "invert"
        }
      }
    },
    {
      "name": "toggle_wifi_interface",
      "ref": "entity.toggle",
      "params": {
        "domain": "peripheral",
        "entity": "interface",
        "variant": "wifi",
        "data": {
          "target_state": "invert"
        }
      }
    },
    {
      "name": "toggle_hdc_interface",
      "ref": "entity.toggle",
      "params": {
        "domain": "peripheral",
        "entity": "interface",
        "variant": "hdc",
        "data": {
          "target_state": "invert"
        }
      }
    }
  ],
  "assertions": [],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Service-backed interface assertions will be added after the MCP executor is wired."
  ]
}
