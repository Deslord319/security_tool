{
  "case_id": "ID-DOMAIN-001",
  "case_name": "Identity Domain Policy Update",
  "module": "identity",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_identity_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "identity"
      }
    },
    {
      "name": "update_identity_domain_policy",
      "ref": "entity.update",
      "params": {
        "domain": "identity",
        "entity": "domain_policy",
        "data": {
          "password_max_age_days": 90,
          "expiration_notify_days": 7,
          "auth_validity_minutes": -1
        }
      }
    }
  ],
  "assertions": [
    {
      "name": "identity_domain_policy_page_marker_visible",
      "type": "assert_text_presence",
      "value": "口令有效期",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Current primary evidence confirms the update executes in the domain policy section.",
    "Getter-backed domain policy assertion will be added later."
  ]
}
