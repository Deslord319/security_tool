{
  "case_id": "ID-PWD-001",
  "case_name": "Identity Password Policy Update",
  "module": "identity",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_identity_page",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "identity"
      }
    },
    {
      "name": "update_identity_password_policy",
      "ref": "entity.update",
      "params": {
        "domain": "identity",
        "entity": "password_policy",
        "data": {
          "min_length": 8,
          "require_uppercase": true,
          "require_lowercase": true,
          "require_digit": true,
          "require_special_char": true
        }
      }
    }
  ],
  "assertions": [
    {
      "name": "identity_page_marker_visible",
      "type": "assert_text_presence",
      "value": "口令复杂度策略",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Current primary evidence confirms the update executes in the expected identity policy context.",
    "Getter-backed assertions will be attached after the identity service read path is wired."
  ]
}
