{
  "case_id": "LOG-STATS-001",
  "case_name": "Log Manage Stats Visible",
  "module": "log-manage",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_log_manage",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "log-manage"
      }
    }
  ],
  "assertions": [
    {
      "name": "log_manage_total_stat_visible",
      "type": "assert_text_presence",
      "value": "总计",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    },
    {
      "name": "log_manage_current_stat_visible",
      "type": "assert_text_presence",
      "value": "当前显示",
      "level": "secondary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This case verifies the log-manage statistics strip is rendered."
  ]
}
