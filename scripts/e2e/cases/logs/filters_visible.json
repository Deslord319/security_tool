{
  "case_id": "LOG-FILTER-001",
  "case_name": "Log Filter After Policy Change",
  "module": "log-manage",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "create_recent_policy_log",
      "ref": "logs.change_any_policy",
      "params": {
        "preferred_module": "firewall"
      }
    },
    {
      "name": "open_log_manage",
      "ref": "logs.open_list",
      "params": {}
    }
  ],
  "assertions": [
    {
      "name": "log_filter_summary_visible",
      "type": "assert_text_presence",
      "value": "当前显示",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2500,
        "interval_ms": 250
      }
    },
    {
      "name": "policy_change_log_type_visible",
      "type": "assert_text_presence",
      "value": "权限变更日志",
      "level": "secondary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This case produces a real policy operation, enters the log page, and validates the resulting filtered log context exposed by the current UI."
  ]
}
