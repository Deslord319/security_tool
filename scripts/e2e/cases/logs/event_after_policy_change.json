{
  "case_id": "LOG-EVENT-001",
  "case_name": "Log Event After Policy Change",
  "module": "log-manage",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "change_any_policy",
      "ref": "logs.change_any_policy",
      "params": {
        "preferred_module": "firewall"
      }
    },
    {
      "name": "open_log_manage_after_policy_change",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "log-manage"
      }
    }
  ],
  "assertions": [
    {
      "name": "log_manage_page_visible_after_policy_change",
      "type": "assert_text_presence",
      "value": "日志管理",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    },
    {
      "name": "recent_security_logs_exist",
      "type": "hdc_shell_contains",
      "value": "com.huawei.securitytool",
      "level": "secondary",
      "params": {
        "command": "hilog -x | grep com.huawei.securitytool",
        "timeout_sec": 10
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Current primary evidence confirms policy change flow can return to the log page context.",
    "This remains mixed evidence until deeper log page assertions are added."
  ]
}
