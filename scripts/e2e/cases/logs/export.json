{
  "case_id": "LOG-EXPORT-001",
  "case_name": "Log Export Flow",
  "module": "log-manage",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_log_manage",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "log-manage"
      }
    },
    {
      "name": "export_logs",
      "ref": "logs.export",
      "params": {}
    }
  ],
  "assertions": [
    {
      "name": "log_manage_page_visible",
      "type": "assert_text_presence",
      "value": "日志管理",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "Export remains UI-driven, but this case now at least proves the action runs from the correct page context.",
    "Export artifact verification will be attached once filesystem assertions are wired."
  ]
}
