{
  "case_id": "LOG-PAGE-002",
  "case_name": "Log Manage Page Details Visible",
  "module": "log-manage",
  "flow": [
    {
      "name": "launch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "reset_previous_page",
      "ref": "ui.press_key",
      "params": {
        "key": "BACK"
      }
    },
    {
      "name": "relaunch_app",
      "ref": "app.launch",
      "params": {
        "timeout_sec": 20
      }
    },
    {
      "name": "open_log_manage",
      "ref": "navigation.open_page",
      "params": {
        "page_id": "log-manage"
      }
    }
  ],
  "assertions": [
    {
      "name": "log_manage_export_button_visible",
      "type": "assert_text_presence",
      "value": "导出日志",
      "level": "primary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    },
    {
      "name": "log_manage_total_stat_visible",
      "type": "assert_text_presence",
      "value": "总计",
      "level": "secondary",
      "params": {
        "bundle_name": "{{bundle_name}}",
        "present": true,
        "timeout_ms": 2000,
        "interval_ms": 250
      }
    }
  ],
  "result_policy": {
    "allow_unknown": true,
    "stop_on_failure": true
  },
  "notes": [
    "This case supplements log-manage coverage with a reset-safe page reachability check using stable first-screen elements."
  ]
}
